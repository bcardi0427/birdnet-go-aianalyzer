# Development Environment Variables for BirdNET-Go AI Analyzer
# Copy this file to .env and adjust variables as needed, or define them in your shell environment.

# Windows Developer Settings
# Specify the absolute path containing tensorflowlite_c.dll and header files.
# This is required by build.ps1, run_tests.ps1, setup_env.bat, and setup_env.ps1.
TENSORFLOW_PATH=C:\path\to\tensorflow
